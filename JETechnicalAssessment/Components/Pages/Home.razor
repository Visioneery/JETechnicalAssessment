@page "/"
@rendermode InteractiveServer
@using JETechnicalAssessment.Models
@using JETechnicalAssessment.Services
@inject IMovieService MovieService
@inject MovieSearchState MovieSearchState

<div class="container py-5">
    <div class="row justify-content-center mb-4">
        <div class="col-lg-8 text-center">
            <h1 class="display-5 fw-bold">Movie Search</h1>
            <p class="text-muted mb-0">Search films and view details instantly.</p>
        </div>
    </div>

    <div class="row justify-content-center mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3 p-md-4">
                    <div class="position-relative">
                        <div class="input-group input-group-lg shadow-sm">
                            <input @bind="query"
                                   @bind:event="oninput"
                                   @onfocus="() => showRecentSearches = true"
                                   @onblur="() => showRecentSearches = false"
                                   @onkeydown="HandleKeyDown"
                                   class="form-control shadow-none"
                                   placeholder="Movie title..." />

                            <button @onclick="() => Search()"
                                    class="btn btn-dark px-4"
                                    disabled="@isSearching">
                                @(isSearching ? "Searching..." : "Search")
                            </button>
                        </div>

                        @if (showRecentSearches && VisibleRecentSearches.Any())
                        {
                            <div class="position-absolute top-100 start-0 w-100 mt-2 z-3">
                                <div class="list-group shadow-sm rounded-3 overflow-hidden">
                                    @foreach (var search in VisibleRecentSearches)
                                    {
                                        <button type="button"
                                                class="list-group-item list-group-item-action text-start py-3 border-0"
                                                @onmousedown:preventDefault="true"
                                                @onclick="() => Search(search)">
                                            @search
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isSearching)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Loading results...</p>
        </div>
    }
    else if (hasSearched && results.Search.Count == 0)
    {
        <div class="alert alert-light border text-center">
            No movies found.
        </div>
    }
    else if (results.Search.Count > 0)
    {
        <div class="row g-4">
            @foreach (var movie in results.Search)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <MovieCard Movie="movie" />
                </div>
            }
        </div>
    }
</div>

@code {
    private string query = string.Empty;
    private SearchResults results = new();
    private bool isSearching;
    private bool hasSearched;
    private bool showRecentSearches;
    private List<string> recentSearches = [];

    private IEnumerable<string> VisibleRecentSearches =>
        string.IsNullOrWhiteSpace(query)
            ? recentSearches
            : recentSearches.Where(x => x.Contains(query, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        recentSearches = await MovieService.GetRecentSearchesAsync();

        if (!string.IsNullOrWhiteSpace(MovieSearchState.LastQuery) && MovieSearchState.LastResults is not null)
        {
            query = MovieSearchState.LastQuery;
            results = MovieSearchState.LastResults;
            hasSearched = true;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Enter":
                await Search();
                break;

            case "Escape":
                showRecentSearches = false;
                break;
        }
    }

    private async Task Search(string? search = null)
    {
        showRecentSearches = false;

        if (search is not null)
        {
            query = search;
        }

        if (string.IsNullOrWhiteSpace(query))
        {
            results = new();
            hasSearched = true;
            return;
        }

        isSearching = true;
        hasSearched = true;

        try
        {
            results = await MovieService.SearchMoviesAsync(query);
            recentSearches = await MovieService.GetRecentSearchesAsync();

            MovieSearchState.LastQuery = query;
            MovieSearchState.LastResults = results;
        }
        finally
        {
            isSearching = false;
        }
    }
}