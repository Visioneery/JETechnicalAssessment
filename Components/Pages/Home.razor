@page "/"
@rendermode InteractiveServer
@using JETechnicalAssessment.Models
@using JETechnicalAssessment.Services
@inject IMovieService MovieService

<div class="container py-5">
    <div class="row justify-content-center mb-4">
        <div class="col-lg-8 text-center">
            <h1 class="display-5 fw-bold">Movie Search</h1>
            <p class="text-muted mb-0">Search films and view details instantly.</p>
        </div>
    </div>

    <div class="row justify-content-center mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3 p-md-4">
                    <div class="input-group">
                        <input @bind="query"
                               @bind:event="oninput"
                               class="form-control form-control-lg"
                               placeholder="Movie title..." />
                        <button @onclick="Search"
                                class="btn btn-dark"
                                disabled="@isSearching">
                            @(isSearching ? "Searching..." : "Search")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isSearching)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Loading results...</p>
        </div>
    }
    else if (hasSearched && results?.Search is { Count: 0 })
    {
        <div class="alert alert-light border text-center">
            No movies found.
        </div>
    }
    else if (results?.Search is { Count: > 0 })
    {
        <div class="row g-4">
            @foreach (var movie in results.Search)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <MovieCard Movie="movie" />
                </div>
            }
        </div>
    }
</div>

@code {
    private string query = string.Empty;
    private OmdbSearchResults? results;
    private bool isSearching;
    private bool hasSearched;

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            results = new OmdbSearchResults();
            hasSearched = true;
            return;
        }

        isSearching = true;
        hasSearched = true;

        results = await MovieService.SearchMoviesAsync(query);

        isSearching = false;
    }
}