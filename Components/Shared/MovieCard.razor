<div class="card h-100 border-0 shadow-sm movie-card">
    <div class="position-relative">
        <img src="@(Movie.Poster != "N/A" ? Movie.Poster : "https://via.placeholder.com/300x450?text=No+Image")"
             class="card-img-top"
             style="height: 320px; object-fit: cover;"
             alt="@Movie.Title" />

        <span class="badge bg-dark position-absolute top-0 end-0 m-2">
            @Movie.Type
        </span>
    </div>

    <div class="card-body d-flex flex-column">
        <h6 class="card-title mb-1 text-truncate">@Movie.Title</h6>
        <p class="text-muted small mb-3">@Movie.Year</p>

        <div class="mt-auto">
            <a href="/details/@Movie.imdbID" class="btn btn-sm btn-outline-dark">
                View Details
            </a>
        </div>
    </div>
</div>

@code {
    [Parameter] public Search Movie { get; set; } = default!;
}